program Test4

const int MAX = 10;
const char LETTER = 'A';
const bool FLAG = true;

enum Color { RED = 1, GREEN, BLUE = 5 }

int globalVar;
int globalArr[];


{


	int sum(int a, int b) int result;{
	    result = a + b;
	    return result;
	}
	
	int compute(int x, int y[]) int i, s;{
	    s = 0;
	
	    for(i = 0; i < y.length; i = i + 1) {
	        if(i % 2 == 0)
	            continue;
	        s = s + y[i];
	        if(s > 100)
	            break;
	    }
	
	    return x + s;
	}
	
	void main() int i; int arr[]; int value; 
	{
	    
	
	    arr = new int[MAX];
	
	    for(i = 0; i < MAX; i = i + 1)
	        arr[i] = i * 2;
	
	    value = compute(5, arr);
	
	    switch(value) {
	        case 0:
	            print(0);
	        case 10:
	            print(10);
	        case 20:
	            print(20);
	    }
	
	    value = value > 10 ? value : 10;
	
	    print(value, 5);
	
	    globalVar = sum(value, 3);
	    print(globalVar);
	}

}
